{
  "manifest_version": 3,
  "name": "英文單字 OCR 速查",
  "version": "0.1.0",
  "description": "用快捷鍵或右鍵選單框選畫面英文單字，立即取得中文翻譯、詞性、例句，並自動收錄到個人單字卡。",

  "permissions": [
    "contextMenus",
    "storage",
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://generativelanguage.googleapis.com/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "英文單字 OCR 速查"
  },

  "options_page": "options/options.html",

  "commands": {
    "start-ocr": {
      "suggested_key": {
        "default": "Ctrl+Shift+O",
        "mac": "Command+Shift+O"
      },
      "description": "開始螢幕 OCR 選取英文單字"
    }
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["services/*.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
